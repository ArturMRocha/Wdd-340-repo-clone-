<header class="site-header">
  <div class="logo">
    <a href="/" title="Go to Home Page">CSE Motors</a>
  </div>
  <div class="account">
  <% if (locals.loggedin) { %>
    <a title="Click to access account management" href="/account/">Welcome <%= locals.accountData.account_firstname %></a>
    <a title="Click to log out" href="/account/logout">Logout</a>
  <% } else { %>
    <a title="Click to log in" href="/account/login">My Account</a>
  <% } %>
</div>
</header>